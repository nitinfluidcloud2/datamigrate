# Step 1: Whitelist iSCSI initiator
curl -sk -u $NUTANIX_USERNAME:$NUTANIX_PASSWORD -X POST -H "Content-Type: application/json" -H "NTNX-Request-Id: $(uuidgen)" -d '{"iscsiInitiatorName":"iqn.2026-01.com.datamigrate:initiator"}' "https://cluster-1919.nutanix.ovh.us:9440/api/volumes/v4.1/config/volume-groups/a49de8e5-8272-41fc-6338-98532deeb8ad/\$actions/attach-iscsi-client"

# Step 2: Read VG over iSCSI → qcow2
qemu-img convert --image-opts "driver=iscsi,transport=tcp,portal=172.16.3.254:3260,target=iqn.2010-06.com.nutanix:datamigrate-ubuntu10-a49de8e5-8272-41fc-6338-98532deeb8ad,lun=0,initiator-name=iqn.2026-01.com.datamigrate:initiator" -O qcow2 /tmp/ubuntu10-disk.qcow2

# Step 3: Create image
curl -sk -u $NUTANIX_USERNAME:$NUTANIX_PASSWORD -X POST -H "Content-Type: application/json" -d '{"spec":{"name":"ubuntu10-migrated-disk","description":"Migrated from VMware VG","resources":{"image_type":"DISK_IMAGE"}},"metadata":{"kind":"image"}}' "https://cluster-1919.nutanix.ovh.us:9440/api/nutanix/v3/images"

# Step 4: Get image UUID
curl -sk -u $NUTANIX_USERNAME:$NUTANIX_PASSWORD -X POST -H "Content-Type: application/json" -d '{"kind":"image","filter":"name==ubuntu10-migrated-disk"}' "https://cluster-1919.nutanix.ovh.us:9440/api/nutanix/v3/images/list" | python3 -m json.tool | grep -E '"uuid"'

# Step 5: Upload qcow2 (replace IMAGE_UUID)
curl -sk -u $NUTANIX_USERNAME:$NUTANIX_PASSWORD -X PUT -H "Content-Type: application/octet-stream" -T /tmp/ubuntu10-disk.qcow2 "https://cluster-1919.nutanix.ovh.us:9440/api/nutanix/v3/images/IMAGE_UUID/file"

# Step 6: Create VM (replace IMAGE_UUID)
curl -sk -u $NUTANIX_USERNAME:$NUTANIX_PASSWORD -X POST -H "Content-Type: application/json" -d '{"spec":{"name":"ubuntu10-ahv","description":"Migrated from VMware","resources":{"num_sockets":1,"num_vcpus_per_socket":1,"memory_size_mib":2048,"power_state":"ON","machine_type":"PC","boot_config":{"boot_type":"UEFI"},"disk_list":[{"data_source_reference":{"kind":"image","uuid":"IMAGE_UUID"},"device_properties":{"device_type":"DISK","disk_address":{"adapter_type":"SCSI","device_index":0}}}],"nic_list":[]},"cluster_reference":{"kind":"cluster","uuid":"00063ca3-b484-4dba-605d-66f6fc6cf210"}},"metadata":{"kind":"vm"}}' "https://cluster-1919.nutanix.ovh.us:9440/api/nutanix/v3/vms"
